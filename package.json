{
  "name": "projeto-automacao",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test": "cypress run",
    "test:api": "cypress run --spec \"cypress/tests/API/**/*.cy.js\"",
    "test:e2e": "cypress run --spec \"cypress/tests/E2E/**/*.cy.js\"",
    "test:cucumber": "cypress run --spec \"cypress/tests/cucumber/features/**/*.feature\"",
    "allure:clean": "node -e \"const fs=require('fs');fs.rmSync('allure-results',{recursive:true,force:true});fs.rmSync('allure-report',{recursive:true,force:true})\"",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "test:report": "npm run allure:clean && npm run cy:run && npm run allure:generate && npm run allure:open",
    "k6:load": "k6 run k6/tests/books-load.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^24.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "@types/k6": "^2.0.0",
    "allure-commandline": "^2.43.0",
    "allure-cypress": "^3.10.0",
    "cypress": "^15.17.0",
    "cypress-on-fix": "^1.1.0",
    "esbuild": "^0.28.1"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": "cypress/tests/cucumber/step_definitions/**/*.{js,ts}"
  }
}
